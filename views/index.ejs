<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>Catálogo de libros</title>
  </head>
  <body>
    <h1>Catálogo de libros</h1>
    <p><a href="/libros/nuevo">+ Agregar libro</a></p>

    <!-- Con la base recién creada no hay documentos todavía. -->
    <% if (!libros.length) { %>
    <p>Todavía no hay libros. <a href="/libros/nuevo">Agrega el primero</a>.</p>
    <% } else { %>
    <table border="1" cellpadding="6">
      <thead>
        <tr>
          <th>ID</th>
          <th>Título</th>
          <th>Autor</th>
          <th>Año</th>
          <th>Disponible</th>
        </tr>
      </thead>
      <tbody>
        <!-- <% %> ejecuta JS (aquí un bucle); <%= %> imprime un valor escapado. -->
        <% libros.forEach((l) => { %>
        <tr>
          <!-- Ahora el id es el _id que genera MongoDB, no un número nuestro. -->
          <td><%= l._id %></td>
          <!-- El enlace arma la URL de detalle con el _id de cada libro. -->
          <td><a href="/libros/<%= l._id %>/ver"><%= l.titulo %></a></td>
          <td><%= l.autor %></td>
          <!-- anio es opcional: puede no venir en el documento. -->
          <td><%= l.anio ?? "—" %></td>
          <td><%= l.disponible ? "Sí" : "No" %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </body>
</html>

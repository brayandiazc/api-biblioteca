# Copia este archivo a .env y pon tu URL real. El .env NO se sube a Git:
# la URL de Atlas lleva usuario y contraseña.
#
# Atlas: Connect → Drivers → Node.js. Recuerda reemplazar <db_password>
# y agregar el nombre de la base (/biblioteca) antes del "?".
MONGODB_URI="mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/biblioteca?retryWrites=true&w=majority"

# Local (alternativa, sin Atlas):
# MONGODB_URI="mongodb://127.0.0.1:27017/biblioteca"

PORT=3000
